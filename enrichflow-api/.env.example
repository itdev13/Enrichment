# ---- Server ----
PORT=3010
NODE_ENV=development
BASE_URL=http://localhost:3010

# ---- MongoDB (required) ----
# A connection is mandatory — the server exits on boot if this is unset or unreachable.
# Use a local mongod or a MongoDB Atlas SRV string. (The `npm run enrich:local` mock test
# does NOT need a DB and runs without this.)
MONGODB_URI=mongodb://localhost:27017/enrichflow

# ---- GoHighLevel OAuth (Marketplace app credentials) ----
# Create an app at https://marketplace.gohighlevel.com and copy these in.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_APP_ID=
# Shared Secret (Advanced Settings -> Auth) — decrypts the SSO user/location context
# that GHL posts to the Custom Page, so locationId resolves automatically (no manual entry).
GHL_APP_SHARED_SECRET=
# Redirect URI must EXACTLY match the one configured on the marketplace app.
# Local testing requires a public tunnel (see README) e.g. https://<sub>.trycloudflare.com/oauth/callback
GHL_REDIRECT_URI=http://localhost:3010/oauth/callback
# Space-separated scopes requested at install time.
GHL_SCOPES=contacts.readonly contacts.write locations.readonly users.readonly oauth.readonly

# GHL API hosts (defaults are correct for production GHL; override only for staging)
GHL_API_URL=https://services.leadconnectorhq.com
GHL_OAUTH_URL=https://services.leadconnectorhq.com/oauth

# ---- Enrichment providers ----
# ENRICH_PRIMARY / ENRICH_FALLBACK select which providers run in the waterfall.
# Use "mock" for local testing with no external API keys / no cost.
ENRICH_PRIMARY=mock
ENRICH_FALLBACK=mock

# Real provider keys (only needed once you switch off "mock")
PROSPEO_API_KEY=
PDL_API_KEY=

# ---- Subscription (MANDATORY monthly plan) ----
# Every install requires an active recurring subscription (collected by GHL). The gate is on by
# default; set to false to bypass for pure-local testing.
SUBSCRIPTION_REQUIRED=true
# Default plan (used when a planId isn't in PLANS_JSON below).
PLAN_NAME=Starter
PLAN_PRICE_USD=29
# Credits included each month with the plan; consumed before any pay-as-you-go wallet overage.
PLAN_INCLUDED_CREDITS=300
# OPTIONAL multi-tier catalog. GHL only sends a planId on INSTALL/PLAN_CHANGE — we map it here to
# the credit allowance. Keys are GHL marketplace plan ids. Unknown ids fall back to the default plan.
# PLANS_JSON={"<starterPlanId>":{"name":"Starter","priceUsd":29,"includedCredits":300},"<growthPlanId>":{"name":"Growth","priceUsd":99,"includedCredits":1500}}

# ---- Billing (usage overage beyond included credits) ----
# Skip GHL wallet charges while testing locally.
BILLING_ENABLED=false
# Retail price per credit (USD) for overage. 1 basic = 1 credit, +email = 1, +phone = 5.
CREDIT_PRICE_USD=0.05
# GHL Marketplace usage meter id (create the meter in the app's billing config).
GHL_METER_ID=
